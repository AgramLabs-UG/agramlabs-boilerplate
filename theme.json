{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"useRootPaddingAwareAlignments": true,
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{ "slug": "base", "name": "Base", "color": "#ffffff" },
				{ "slug": "surface", "name": "Surface", "color": "#f5f7fa" },
				{ "slug": "contrast", "name": "Contrast", "color": "#111827" },
				{ "slug": "muted", "name": "Muted", "color": "#5f6b7a" },
				{ "slug": "border", "name": "Border", "color": "#d8dee8" },
				{ "slug": "primary", "name": "Primary", "color": "#155eef" },
				{ "slug": "secondary", "name": "Secondary", "color": "#13a886" }
			]
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{ "slug": "20", "name": "2XS", "size": "0.5rem" },
				{ "slug": "30", "name": "XS", "size": "0.75rem" },
				{ "slug": "40", "name": "S", "size": "1rem" },
				{ "slug": "50", "name": "M", "size": "clamp(1.25rem, 2vw, 2rem)" },
				{ "slug": "60", "name": "L", "size": "clamp(2rem, 4vw, 4rem)" },
				{ "slug": "70", "name": "XL", "size": "clamp(3rem, 6vw, 6rem)" }
			],
			"units": [ "%", "px", "em", "rem", "vh", "vw" ]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontFamilies": [
				{
					"slug": "system-sans",
					"name": "System Sans",
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Inter, Helvetica, Arial, sans-serif"
				}
			],
			"fontSizes": [
				{ "slug": "small", "name": "Small", "size": "0.875rem" },
				{ "slug": "medium", "name": "Medium", "size": "1rem" },
				{ "slug": "large", "name": "Large", "size": "clamp(1.125rem, 1.2vw, 1.25rem)" },
				{ "slug": "x-large", "name": "Extra Large", "size": "clamp(1.75rem, 3vw, 2.75rem)" },
				{ "slug": "xx-large", "name": "XX Large", "size": "clamp(2.25rem, 5vw, 4.75rem)" }
			]
		}
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"spacing": {
			"blockGap": "var:preset|spacing|50",
			"padding": {
				"left": "var:preset|spacing|50",
				"right": "var:preset|spacing|50"
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|system-sans",
			"fontSize": "var:preset|font-size|medium",
			"lineHeight": "1.65"
		},
		"elements": {
			"button": {
				"border": { "radius": "0.375rem" },
				"color": {
					"background": "var:preset|color|primary",
					"text": "var:preset|color|base"
				},
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"right": "1.125rem",
						"bottom": "0.75rem",
						"left": "1.125rem"
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|medium",
					"fontWeight": "700"
				}
			},
			"heading": {
				"typography": {
					"fontWeight": "750",
					"lineHeight": "1.1"
				}
			},
			"link": {
				"color": { "text": "var:preset|color|primary" }
			}
		},
		"blocks": {
			"core/button": {
				"border": { "radius": "0.375rem" }
			},
			"core/group": {
				"spacing": {
					"blockGap": "var:preset|spacing|50"
				}
			},
			"core/navigation": {
				"typography": {
					"fontSize": "var:preset|font-size|small",
					"fontWeight": "700"
				}
			},
			"core/post-title": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large"
				}
			}
		}
	},
	"templateParts": [
		{ "area": "header", "name": "header", "title": "Header" },
		{ "area": "footer", "name": "footer", "title": "Footer" }
	],
	"customTemplates": [
		{
			"name": "blank",
			"postTypes": [ "page" ],
			"title": "Blank page"
		}
	]
}
