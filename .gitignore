# Dependencies
node_modules/

# Package manager noise
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment and local secrets
.env
.env.*
!.env.example
*.local

# Build and tool caches
.cache/
.parcel-cache/
.sass-cache/
.stylelintcache
.eslintcache
.vite/
coverage/
release/

# Temporary files
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor and IDE folders
.idea/
.vscode/
*.code-workspace

# Local-only project notes
docs/

# WordPress and Local app generated files
wp-content/uploads/
wp-content/upgrade/
wp-content/backup*/
*.sql
*.sqlite
*.sqlite3

# Keep compiled theme assets and lockfile tracked.
!assets/
!assets/css/
!assets/js/
!assets/css/*.css
!assets/js/*.js
!package-lock.json
